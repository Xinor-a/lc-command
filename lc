#!/usr/bin/env bash
# lc - line-copy: select lines from piped input and copy to clipboard
# Usage: some_command | lc
#   ↑/↓  : navigate
#   Enter : toggle select/deselect
#   d     : done — copy selected lines to clipboard
#   q     : quit without copying

set -euo pipefail

# --- Parse options ---
quote_char="auto"
while [ $# -gt 0 ]; do
  case "$1" in
    --quote)
      shift
      case "${1:-}" in
        single) quote_char="'" ;;
        double) quote_char='"' ;;
        none) quote_char="" ;;
        auto) quote_char="auto" ;;
        *) echo "Usage: --quote single|double|none|auto" >&2; exit 1 ;;
      esac
      shift
      ;;
    *) echo "Unknown option: $1" >&2; exit 1 ;;
  esac
done

# --- Read stdin into array ---
if [ -t 0 ]; then
  echo "Usage: command | lc" >&2
  exit 1
fi

lines=()
while IFS= read -r line; do
  lines+=("$line")
done
exec < /dev/tty  # reconnect stdin to terminal for interactive input

if [ ${#lines[@]} -eq 0 ]; then
  echo "No input." >&2
  exit 1
fi

# --- Clipboard helper ---
copy_to_clipboard() {
  if command -v pbcopy &>/dev/null; then
    printf '%s' "$1" | pbcopy
  elif command -v wl-copy &>/dev/null; then
    printf '%s' "$1" | wl-copy
    printf '%s' "$1" | wl-copy --primary
  elif command -v xclip &>/dev/null; then
    printf '%s' "$1" | xclip -selection clipboard
    printf '%s' "$1" | xclip -selection primary
  elif command -v xsel &>/dev/null; then
    printf '%s' "$1" | xsel --clipboard --input
    printf '%s' "$1" | xsel --primary --input
  elif command -v clip.exe &>/dev/null; then
    printf '%s' "$1" | clip.exe
  else
    echo "No clipboard tool found (pbcopy/wl-copy/xclip/xsel/clip.exe)." >&2
    return 1
  fi
}

# --- TUI state ---
cursor=0
total=${#lines[@]}
selected_order=()           # indices in selection order
declare -A is_selected=()   # map: index -> 1

# --- Rebuild selection number map (avoids subshell per line) ---
rebuild_sel_map() {
  sel_map=()
  local n=1
  if [ ${#selected_order[@]} -gt 0 ]; then
    for s in "${selected_order[@]}"; do
      sel_map[$s]=$n
      n=$((n + 1))
    done
  fi
}
declare -A sel_map=()

# --- Drawing (buffered) ---
draw() {
  rebuild_sel_map
  local buf
  buf=$'\e['"${start_row};1H"
  for i in "${!lines[@]}"; do
    local marker="   "
    if [[ -n "${sel_map[$i]:-}" ]]; then
      marker=$'\e[32m'"$(printf '%2d' "${sel_map[$i]}")"$'\e[0m '
    fi
    if [ "$i" -eq "$cursor" ]; then
      buf+=$'\e[2K\e[7m '"${marker} ${lines[$i]} "$'\e[0m\n'
    else
      buf+=$'\e[2K '"${marker} ${lines[$i]}"$'\n'
    fi
  done
  printf '%s' "$buf"
}

initial_draw() {
  for (( i = 0; i < total; i++ )); do
    echo
  done
  printf '\e[%dA' "$total"

  IFS=';' read -sdR -p $'\e[6n' _row _col < /dev/tty
  start_row=${_row#*[}

  local buf=""
  for i in "${!lines[@]}"; do
    local marker="   "
    if [ "$i" -eq "$cursor" ]; then
      buf+=$'\e[7m '"${marker} ${lines[$i]} "$'\e[0m\n'
    else
      buf+=" ${marker} ${lines[$i]}"$'\n'
    fi
  done
  printf '%s' "$buf"
}

# --- Flush pending input ---
flush_input() {
  while read -rsn1 -t 0.01 _discard; do :; done
}

# --- Toggle selection ---
toggle() {
  local idx=$1
  if [[ -n "${is_selected[$idx]:-}" ]]; then
    unset "is_selected[$idx]"
    local new_order=()
    if [ ${#selected_order[@]} -gt 0 ]; then
      for s in "${selected_order[@]}"; do
        [ "$s" -ne "$idx" ] && new_order+=("$s")
      done
    fi
    selected_order=("${new_order[@]+"${new_order[@]}"}")
  else
    is_selected[$idx]=1
    selected_order+=("$idx")
  fi
}

# --- Main loop ---
set +e  # disable errexit for interactive TUI
printf '\e[?25l'  # hide cursor
trap 'printf "\e[?25h"' EXIT  # restore cursor on exit

initial_draw

while true; do
  IFS= read -rsn1 key
  case "$key" in
    $'\x1b')  # escape sequence
      read -rsn2 seq
      case "$seq" in
        '[A') [ "$cursor" -gt 0 ] && cursor=$((cursor - 1)) || true ;;   # up
        '[B') [ "$cursor" -lt $((total - 1)) ] && cursor=$((cursor + 1)) || true ;;  # down
      esac
      ;;
    ''|' ')  # Enter or Space
      toggle "$cursor"
      ;;
    k) [ "$cursor" -gt 0 ] && cursor=$((cursor - 1)) || true ;;           # vim up
    j) [ "$cursor" -lt $((total - 1)) ] && cursor=$((cursor + 1)) || true ;;  # vim down
    d|D)  # done
      break
      ;;
    q|Q)  # quit
      printf '\e[?25h'
      echo "Cancelled." >&2
      exit 0
      ;;
  esac
  draw
  flush_input
done

printf '\e[?25h'  # show cursor

# --- Build result and copy ---
if [ ${#selected_order[@]} -eq 0 ]; then
  echo "Nothing selected." >&2
  exit 0
fi

result_parts=()
for idx in "${selected_order[@]}"; do
  trimmed="${lines[$idx]}"
  trimmed="${trimmed#"${trimmed%%[![:space:]]*}"}"
  trimmed="${trimmed%"${trimmed##*[![:space:]]}"}"
  if [ -z "$trimmed" ]; then
    continue
  fi
  if [ "$quote_char" = "auto" ]; then
    if [[ "$trimmed" =~ [[:space:]\&\|\;\(\)\<\>\$\`\\!#\*\?] ]]; then
      if [[ "$trimmed" != *"'"* ]]; then
        result_parts+=("'${trimmed}'")
      else
        result_parts+=("\"${trimmed}\"")
      fi
    else
      result_parts+=("$trimmed")
    fi
  else
    result_parts+=("${quote_char}${trimmed}${quote_char}")
  fi
done

result=$(IFS=' '; echo "${result_parts[*]}")

if copy_to_clipboard "$result"; then
  echo "Copied: $result" >&2
else
  echo "Result: $result" >&2
  exit 1
fi
